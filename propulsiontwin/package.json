{
  "name": "propulsiontwin",
  "version": "2.0.0",
  "description": "PropulsionTwin - Digital Twin Simulation Environment for Jet, Rocket, Electric & Hybrid Propulsion Systems",
  "main": "electron/main.js",
  "author": "PropulsionTwin Contributors",
  "license": "MIT",
  "private": true,
  "homepage": "./",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -s first -n VITE,ELECTRON \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "electron:build:linux": "vite build && electron-builder --linux",
    "start": "npm run electron:dev"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.1",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "electron": "30.5.1",
    "electron-builder": "24.13.3",
    "vite": "5.4.8",
    "wait-on": "7.2.0"
  },
  "build": {
    "appId": "com.propulsiontwin.app",
    "productName": "PropulsionTwin",
    "directories": {
      "output": "dist-electron",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "public/icon.png",
      "category": "Science"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PropulsionTwin"
    }
  }
}
